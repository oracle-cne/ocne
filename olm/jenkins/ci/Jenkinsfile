@Library('olcne-pipeline')
import com.oracle.olcne.pipeline.BranchPattern

olcnePipeline(
    branchPattern: new BranchPattern(master: 'release/.*', feature: '(?!^release/.*$)(^.*$)'),
    customStages: [container: [enabled: false]],
    platforms: ['ol8', 'ol9', 'ol10'],
    architectures: ['x86_64', 'aarch64'],
    ol8ModulesToDisable: ['go-toolset:ol8'],
    yumOL8Repos: ['ol8_codeready_builder', 'ol8_UEKR7'],
    yumOL9Repos: ['ol9_codeready_builder', 'ol9_UEKR7'],
    yumOL10Repos: ['ol10_codeready_builder', 'ol10_UEKR8'],
    preBuildOL8Commands: [
      "make build/catalog build/developer-catalog",
    ],
    preBuildOL9Commands: [
      "make build/catalog build/developer-catalog",
    ],
    preBuildOL10Commands: [
      'git config --global --add safe.directory "$(pwd)"',
      '''REQ=$(sed -n 's/^toolchain go//p; s/^go //p' go.mod | sort -rV | head -n1)
dnf erase -y golang
AVAIL=$(dnf list --showduplicates golang | awk '$1 ~ /^golang(\\.[^[:space:]]+)?$/ {print $2}' | sed 's/-.*//' | sort -rV | awk -v req="$REQ" '
BEGIN {
  split(req, version, ".")
  series = version[1] "." version[2]
}
{
  split($0, candidate, ".")
  if (candidate[1] "." candidate[2] == series) {
    print
    exit
  }
}')
if [ -z "$AVAIL" ] || [ "$(printf '%s\n%s\n' "$REQ" "$AVAIL" | sort -V | head -n1)" != "$REQ" ]; then
  echo "No supported golang package found for $REQ"
  exit 1
fi
dnf install -y "golang-$AVAIL"
go version''',
      "make build/catalog build/developer-catalog",
    ],
)
